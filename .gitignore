# Python
__pycache__/
*.py[cod]
*.so
build/
dist/
*.egg-info/
.eggs/

# Environments / tooling caches
.venv/
.env
.ruff_cache/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Kanomori runtime artifacts: derived media (thumbnails), KITS subprocess logs/SRTs.
# We store derived indexes + short preview thumbnails, never redistributed source video.
media/
*.log

# Source clips you ingest manually (inputs). Large + copyright-sensitive — never committed.
# The folder's README + batch manifest are tracked so the layout is documented.
# Ignore the *contents* (samples/*) not the dir itself, so the negations below apply.
samples/*
!samples/README.md
!samples/README.zh-CN.md
!samples/manifest.jsonl

# OS
.DS_Store

# IDE
.idea/
.vscode/
