# Kanomori configuration (copy to .env and adjust). Loaded by src/kanomori/config.py.

# PostgreSQL + pgvector. Matches docker-compose.yml (host port 5433).
KANOMORI_DATABASE_URL=postgresql://kanomori:kanomori@localhost:5433/kanomori

# Path to the sibling KITS checkout. Ingestion shells out to `uv run kits subtitle`
# with this as the working directory. KITS must be `uv sync`-ed in its own venv.
KANOMORI_KITS_DIR=/Users/lb/Documents/Code/KITS

# Where derived media (frame thumbnails, KITS SRT/log artifacts) are written.
KANOMORI_MEDIA_ROOT=./media

# Embedding model ids (offline ingestion + online query). Dims are pinned in code:
# BGE-M3 dense = 1024, DINOv2 ViT-B/14 = 768.
KANOMORI_TEXT_MODEL=BAAI/bge-m3
KANOMORI_IMAGE_MODEL=facebook/dinov2-base
KANOMORI_SCENE_MODEL=google/siglip-base-patch16-224

# Audio upload search uses in-process kotoba-whisper for the query clip. This value is
# required before calling POST /search/audio and must match the kotoba-whisper version that
# produced the indexed transcript corpus. Example if the corpus was transcribed with the
# current KITS default:
# KANOMORI_AUDIO_ASR_MODEL=kotoba-tech/kotoba-whisper-v2.2
KANOMORI_AUDIO_CLIP_MAX_SEC=35.0

# OCR settings. Models: legacy_rapidocr, ppocrv5_mobile, ppocrv5_server.
# Backends: onnxruntime, cuda, tensorrt. CUDA/TensorRT are NVIDIA-only and fall back to ONNX
# at runtime when fallback is allowed; benchmark runs fail instead of falling back.
KANOMORI_INGEST_OCR_MODEL=ppocrv5_server
KANOMORI_INGEST_OCR_BACKEND=onnxruntime
KANOMORI_QUERY_OCR_MODEL=ppocrv5_server
KANOMORI_QUERY_OCR_BACKEND=onnxruntime

# Offline worker stage-device affinity. Each eligible ingest stage can be pinned to CPU or GPU.
# cpu = force CPU execution for that stage.
# gpu = require GPU execution for that stage; initialization fails fast if CUDA is unavailable.
# OCR uses these together with the backend settings above:
# - stage_ocr_device=cpu always resolves ingest OCR to onnxruntime
# - stage_ocr_device=gpu requires ingest_ocr_backend=cuda or tensorrt
KANOMORI_STAGE_PARSE_TRANSCRIPT_DEVICE=cpu
KANOMORI_STAGE_OCR_DEVICE=cpu
KANOMORI_STAGE_CLASSIFY_DEVICE=cpu
KANOMORI_STAGE_IMAGE_EMBED_DEVICE=cpu

# --- Distributed ingestion (workers + coordinator) ---
# Where a worker reads source video from. "local" = a directory (media_source_root,
# = samples/ in dev); "webdav" = an HTTP(S) WebDAV share fetched with plain GET.
KANOMORI_MEDIA_SOURCE=local
KANOMORI_MEDIA_SOURCE_ROOT=./samples
# WebDAV base URL + optional basic-auth creds (only used when MEDIA_SOURCE=webdav).
# KANOMORI_MEDIA_SOURCE_URL=https://media.example/dav
# KANOMORI_MEDIA_SOURCE_USER=
# KANOMORI_MEDIA_SOURCE_PASSWORD=

# Shared bearer token authenticating workers to the coordinator /jobs router.
# UNSET => the /jobs API refuses all calls (503), so set this on the coordinator
# and every worker before running distributed. Send over TLS; never logged.
# KANOMORI_COORDINATOR_TOKEN=change-me
# Where a remote worker reaches the coordinator. Default suits a co-located worker.
KANOMORI_COORDINATOR_URL=http://localhost:8000
