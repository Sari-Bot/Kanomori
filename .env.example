# Kanomori configuration (copy to .env and adjust). Loaded by src/kanomori/config.py.

# PostgreSQL + pgvector. Matches docker-compose.yml (host port 5433).
KANOMORI_DATABASE_URL=postgresql://kanomori:kanomori@localhost:5433/kanomori

# Path to the sibling KITS checkout. Ingestion shells out to `uv run kits subtitle`
# with this as the working directory. KITS must be `uv sync`-ed in its own venv.
KANOMORI_KITS_DIR=/Users/lb/Documents/Code/KITS

# Where derived media (frame thumbnails, KITS SRT/log artifacts) are written.
KANOMORI_MEDIA_ROOT=./media

# Embedding model ids (offline ingestion + online query). Dims are pinned in code:
# BGE-M3 dense = 1024, DINOv2 ViT-B/14 = 768.
KANOMORI_TEXT_MODEL=BAAI/bge-m3
KANOMORI_IMAGE_MODEL=facebook/dinov2-base
KANOMORI_SCENE_MODEL=google/siglip-base-patch16-224

# OCR settings. Models: legacy_rapidocr, ppocrv5_mobile, ppocrv5_server.
# Backends: onnxruntime, tensorrt. TensorRT is NVIDIA-only and falls back to ONNX at runtime
# when unavailable; benchmark runs fail instead of falling back.
KANOMORI_INGEST_OCR_MODEL=ppocrv5_server
KANOMORI_INGEST_OCR_BACKEND=onnxruntime
KANOMORI_QUERY_OCR_MODEL=ppocrv5_server
KANOMORI_QUERY_OCR_BACKEND=onnxruntime
