# Copy to .env.cuda-worker and edit before launching docker-compose.cuda-worker.yml.

# Worker identity and coordinator access.
KANOMORI_WORKER_ID=cuda-worker-01
KANOMORI_COORDINATOR_URL=http://coordinator-host:8000
KANOMORI_COORDINATOR_TOKEN=replace-this-shared-secret

# Host paths mounted into the worker container.
# KITS is mounted read/write because it owns its own uv environment and model/runtime files.
KANOMORI_KITS_DIR_HOST=/path/to/KITS
KANOMORI_MEDIA_SOURCE_ROOT_HOST=/path/to/source-store

# Source-store mode. local reads KANOMORI_MEDIA_SOURCE_ROOT_HOST; webdav uses the URL settings.
KANOMORI_MEDIA_SOURCE=local
# KANOMORI_MEDIA_SOURCE_URL=https://dav.example.com/store
# KANOMORI_MEDIA_SOURCE_USER=
# KANOMORI_MEDIA_SOURCE_PASSWORD=

# CUDA OCR/model execution for the offline worker.
KANOMORI_INGEST_OCR_MODEL=ppocrv5_server
KANOMORI_INGEST_OCR_BACKEND=cuda
KANOMORI_STAGE_PARSE_TRANSCRIPT_DEVICE=gpu
KANOMORI_STAGE_OCR_DEVICE=gpu
KANOMORI_STAGE_CLASSIFY_DEVICE=gpu
KANOMORI_STAGE_IMAGE_EMBED_DEVICE=gpu

# Optional image/build overrides.
KANOMORI_CUDA_WORKER_IMAGE=kanomori-cuda-worker:latest
KANOMORI_CUDA_IMAGE=nvidia/cuda:13.0.2-cudnn-runtime-ubuntu24.04
KANOMORI_UV_IMAGE=ghcr.io/astral-sh/uv:0.11.19
